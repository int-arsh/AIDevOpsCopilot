# Copy this file to `.env` and fill in values. Never commit `.env` with real secrets.

# Groq Cloud API key used to call hosted LLMs (e.g. llama-3.3-70b-versatile). Create one at https://console.groq.com/keys under your Groq account.
GROQ_API_KEY=

# GitHub fine-grained or classic personal access token for API calls (issues, repo metadata). Create at https://github.com/settings/tokens with the scopes your automations need.
GITHUB_TOKEN=

# Target repository as `owner/repo` (GitHub username or org, then repository name). Use the same string shown in the repo URL after github.com/.
GITHUB_REPO=

# Base URL of the Prometheus HTTP API (no trailing path). Point at your cluster’s Prometheus or local Prometheus; default is a typical local scrape endpoint.
PROMETHEUS_URL=

# Path to your kubeconfig file so the Kubernetes client and kubectl wrappers know which cluster/context to use. Usually created by `kubectl` after cloud login or minikube/kind setup; leave default if the file lives in the standard location.
KUBECONFIG=

# Runtime mode for the app (e.g. tighter logging, feature flags). Use `development` locally; set to `production` only in deployed environments.
APP_ENV=

# Python/logging verbosity (e.g. DEBUG, INFO, WARNING). Controls how chatty application logs are; INFO is normal for day-to-day runs.
LOG_LEVEL=
