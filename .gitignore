# Ignore virtualenvs, .env secrets, Python caches, IDE files, and local build artifacts.
# Environment and secrets
.env
.env.*
!.env.example

# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging and build outputs
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
htmlcov/
.coverage
.coverage.*
coverage.xml

# Tooling and editor files
.vscode/
.idea/
.DS_Store
*.swp
*.swo
*.log

# Local test/runtime artifacts
*.pid
*.seed
*.tmp

# Optional local config
.python-version

.cursorrules
